import tkinter as tk
import random

# QUESTIONS (question, correct answer, choices)
questions = [
    ("What is the capital of France?", "Paris", ["Paris", "Rome", "Berlin", "Madrid"]),
    ("What is 5 x 6?", "30", ["25", "30", "35", "40"]),
    ("What planet is known as the Red Planet?", "Mars", ["Earth", "Mars", "Jupiter", "Venus"]),
    ("What is the largest animal in the world?", "Blue Whale", ["Elephant", "Blue Whale", "Shark", "Giraffe"]),
    ("How many continents are there?", "7", ["5", "6", "7", "8"]),
    ("What is H2O commonly known as?", "Water", ["Oxygen", "Water", "Hydrogen", "Salt"]),
    ("Who wrote Hamlet?", "Shakespeare", ["Shakespeare", "Tolstoy", "Homer", "Dickens"]),
    ("What is the fastest land animal?", "Cheetah", ["Lion", "Tiger", "Cheetah", "Horse"])
]

class QuizApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Quiz Game")

        self.score = 0
        self.q_index = 0
        self.retry = False

        random.shuffle(questions)
        self.selected_questions = questions[:3]

        self.name = ""

        self.create_start_screen()

    def create_start_screen(self):
        self.clear_screen()

        tk.Label(self.root, text="Enter your name:").pack()
        self.name_entry = tk.Entry(self.root)
        self.name_entry.pack()

        tk.Button(self.root, text="Start Quiz", command=self.start_quiz).pack()

    def start_quiz(self):
        self.name = self.name_entry.get().strip() or "Player"
        self.show_question()

    def show_question(self):
        self.clear_screen()

        if self.q_index >= 3:
            self.show_result()
            return

        q, correct, choices = self.selected_questions[self.q_index]

        tk.Label(self.root, text=f"{self.name}, Question {self.q_index + 1}").pack()
        tk.Label(self.root, text=q).pack()

        self.var = tk.StringVar()

        for choice in choices:
            tk.Radiobutton(self.root, text=choice, variable=self.var, value=choice).pack()

        tk.Button(self.root, text="Submit", command=self.check_answer).pack()

    def check_answer(self):
        selected = self.var.get()
        q, correct, _ = self.selected_questions[self.q_index]

        if selected == correct:
            self.score += 1
            self.q_index += 1
            self.retry = False
            self.show_question()
        else:
            if not self.retry:
                self.retry = True
                self.show_retry(correct)
            else:
                self.retry = False
                self.q_index += 1
                self.show_question()

    def show_retry(self, correct):
        self.clear_screen()
        tk.Label(self.root, text="Wrong! Try again.").pack()
        tk.Button(self.root, text="Retry", command=self.show_question).pack()

    def show_result(self):
        self.clear_screen()

        tk.Label(self.root, text=f"{self.name}, you got {self.score}/3 correct!").pack()

        if self.score == 3:
            msg = "Amazing! Perfect score!"
        elif self.score > 0:
            msg = "Nice try!"
        else:
            msg = "Better luck next time!"

        tk.Label(self.root, text=msg).pack()

    def clear_screen(self):
        for widget in self.root.winfo_children():
            widget.destroy()


# RUN APP
root = tk.Tk()
app = QuizApp(root)
root.mainloop()
